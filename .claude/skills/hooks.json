{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash .cursor/hooks/audit.sh"
      },
      {
        "command": "bash .cursor/hooks/block-dangerous.sh"
      },
      {
        "command": "bash .cursor/hooks/block-git.sh"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "bash .cursor/hooks/audit.sh"
      }
    ],
    "beforeReadFile": [
      {
        "command": "bash .cursor/hooks/redact-secrets.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash .cursor/hooks/audit.sh"
      },
      {
        "command": "bash .cursor/hooks/log-file-changes.sh"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "bash .cursor/hooks/audit.sh"
      }
    ],
    "stop": [
      {
        "command": "bash .cursor/hooks/audit.sh"
      },
      {
        "command": "osascript -e 'display notification \"Tarefa concluída\" with title \"Cursor\"'"
      }
    ]
  }
}